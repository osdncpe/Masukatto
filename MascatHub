SpamTab:AddToggle({
    Name = "Spam Blob Loop",
    Default = false,
    Callback = function(Value)
        spamBlobActive = Value
        
        if spamBlobTask then
            task.cancel(spamBlobTask)
            spamBlobTask = nil
        end
        
        if Value then
            spamBlobTask = task.spawn(function()
                while spamBlobActive do
                    local target = Players:FindFirstChild(spamTarget)
                    if not target then
                        task.wait(0.5)
                        continue
                    end
                    
                    local targetChar = target.Character
                    local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
                    local targetHum = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
                    
                    if not targetRoot or not targetHum or targetHum.Health <= 0 then
                        task.wait(0.5)
                        continue
                    end
                    
                    local myChar = LocalPlayer.Character
                    local myRoot = GetMyRoot()
                    local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")
                    
                    if not myRoot or not myHum then
                        task.wait(0.5)
                        continue
                    end
                    
                    local folder = workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
                    local blob = folder and folder:FindFirstChild("CreatureBlobman")
                    
                    if not blob then
                        pcall(function()
                            ReplicatedStorage.MenuToys.SpawnToyRemoteFunction:InvokeServer(
                                "CreatureBlobman",
                                myRoot.CFrame * CFrame.new(0, 0, -5),
                                Vector3.new(0, 60, 0)
                            )
                        end)
                        task.wait(0.3)
                        folder = workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
                        blob = folder and folder:FindFirstChild("CreatureBlobman")
                        if not blob then
                            task.wait(0.3)
                            continue
                        end
                    end
                    
                    local seat = blob:FindFirstChild("VehicleSeat")
                    if seat and not myHum.Sit then
                        myRoot.CFrame = seat.CFrame + Vector3.new(0, 2, 0)
                        seat:Sit(myHum)
                        task.wait(0.2)
                    end
                    
                    if not myHum.Sit then
                        task.wait(0.3)
                        continue
                    end
                    
                    local leftDetector = blob:FindFirstChild("LeftDetector")
                    local rightDetector = blob:FindFirstChild("RightDetector")
                    local script = blob:FindFirstChild("BlobmanSeatAndOwnerScript", true)
                    
                    if leftDetector and rightDetector and script then
                        local grab = script:FindFirstChild("CreatureGrab")
                        local release = script:FindFirstChild("CreatureRelease")
                        local drop = script:FindFirstChild("CreatureDrop")
                        
                        if grab then
                            local leftWeld = leftDetector:FindFirstChild("LeftWeld")
                            local rightWeld = rightDetector:FindFirstChild("RightWeld")
                            
                            if spamUseBothHands then
                                if leftWeld then
                                    pcall(function() grab:FireServer(leftDetector, targetRoot, leftWeld) end)
                                end
                                if rightWeld then
                                    pcall(function() grab:FireServer(rightDetector, targetRoot, rightWeld) end)
                                end
                            else
                                if leftWeld then
                                    pcall(function() grab:FireServer(leftDetector, targetRoot, leftWeld) end)
                                end
                            end
                            
                            if release then
                                if leftWeld then pcall(function() release:FireServer(leftWeld) end) end
                                if rightWeld and spamUseBothHands then pcall(function() release:FireServer(rightWeld) end) end
                            end
                            
                            pcall(function()
                                ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(targetRoot, targetRoot.CFrame)
                            end)
                            
                            targetRoot.CFrame = targetRoot.CFrame + Vector3.new(0, 2, 0)
                            
                            task.wait(spamBlobSpeed)
                            
                            if drop then
                                if leftWeld then pcall(function() drop:FireServer(leftWeld, targetRoot) end) end
                                if rightWeld and spamUseBothHands then pcall(function() drop:FireServer(rightWeld, targetRoot) end) end
                            end
                            
                            pcall(function()
                                ReplicatedStorage.GrabEvents.DestroyGrabLine:FireServer(targetRoot)
                            end)
                            
                            task.wait(spamBlobSpeed)
                        end
                    end
                    
                    task.wait(spamBlobSpeed)
                end
            end)
        end
    end
})

