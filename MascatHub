            task.spawn(function()
                local isHeld = LocalPlayer:WaitForChild("IsHeld", 10)
                local struggleEvent = ReplicatedStorage:FindFirstChild("CharacterEvents") and ReplicatedStorage.CharacterEvents:FindFirstChild("Struggle")
                
                while antiGrabEnabled do
                    if isHeld and isHeld.Value then
                        local char = LocalPlayer.Character
                        local hrp = char and char:FindFirstChild("HumanoidRootPart")
                        local hum = char and char:FindFirstChildOfClass("Humanoid")
                        
                        if hrp then
                            hrp.Anchored = true
                            hrp.AssemblyLinearVelocity = Vector3.zero
                            hrp.AssemblyAngularVelocity = Vector3.zero
                        end
                        
                        if hum then
                            hum.Sit = false
                            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                            hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
                        end
                        
                        if struggleEvent then
                            pcall(function() struggleEvent:FireServer(LocalPlayer) end)
                        end
                        
                        pcall(function()
                            ReplicatedStorage.CharacterEvents.RagdollRemote:FireServer(hrp, 0)
                            ReplicatedStorage.GameCorrectionEvents.StopAllVelocity:FireServer()
                        end)
                    end
                    task.wait()
                end
            end)
        end
    end
})

